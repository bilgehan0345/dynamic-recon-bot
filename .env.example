# =============================================================================
# ENVIRONMENT VARIABLES — CONFIGURATION TEMPLATE
# =============================================================================
# This file is a public template committed to version control.
# It shows which environment variables are required to run this project.
#
# SETUP INSTRUCTIONS:
#   1. Copy this file and rename it to ".env"
#   2. Replace each placeholder value with your actual credentials
#   3. Never share or commit your ".env" file — it is listed in .gitignore
# =============================================================================


# -----------------------------------------------------------------------------
# SHODAN API KEY
# Required for host and service discovery in Phase 2.
# Get your free API key at: https://account.shodan.io
# -----------------------------------------------------------------------------
SHODAN_API_KEY=your_shodan_api_key_here

# -----------------------------------------------------------------------------
# ALIENVAULT OTX API KEY
# Optional but recommended to prevent 429 Rate Limit errors.
# Get your free API key at: https://otx.alienvault.com
# -----------------------------------------------------------------------------
ALIENVAULT_API_KEY=your_alienvault_api_key_here
